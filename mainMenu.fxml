<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="baseLayerBorderPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="smartHomeProject.MainMenuController">
   <left>
      <VBox fx:id="ruleVBox" maxHeight="1.7976931348623157E308" prefWidth="150.0" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
         <children>
            <Label fx:id="rulesLabel" text="Rules">
               <font>
                  <Font name="Comic Sans MS" />
               </font>
            </Label>
            <ListView fx:id="ruleListView" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="5.0" top="5.0" />
               </VBox.margin>
            </ListView>
            <Label fx:id="errorLabel" />
            <Button fx:id="deleteRuleButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Delete Rule">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="createRuleButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Create Rule">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin></Button>
            <Button fx:id="registerDeviceButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Register Device">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="registerRoomButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Register Room">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
   		<fx:include fx:id="homeView" source="homeView.fxml" />
   	</center>
   <right>
      <StackPane fx:id="rightSideStackPane" prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <VBox fx:id="ruleBilderVbox" prefHeight="200.0" prefWidth="100.0">
               <children>
                   <fx:include fx:id="createRule" source="createRule.fxml" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
            <VBox fx:id="registerRoomVBox" prefHeight="200.0" prefWidth="100.0">
               <children>
                  <fx:include fx:id="registerRoom" source="RegisterRoom.fxml" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
            <VBox fx:id="registerDeviceVBox" prefHeight="200.0" prefWidth="100.0">
               <children>
                  <fx:include fx:id="registerDevice" source="RegisterDevice.fxml" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
      </StackPane>
   </right>
   <top>
      <HBox fx:id="topBarHBox" alignment="CENTER_LEFT" prefHeight="30.0" prefWidth="866.0" style="-fx-background-color: ebebeb;" BorderPane.alignment="CENTER_LEFT">
         <children>
            <HBox fx:id="userHBox" alignment="CENTER_RIGHT" maxWidth="1.7976931348623157E308">
               <children>
                  <Label fx:id="userLabel" text="User - Admin" />
               </children>
               <HBox.margin>
                  <Insets right="10.0" />
               </HBox.margin>
            </HBox>
            <HBox fx:id="timeHBox" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308">
               <children>
                  <Label fx:id="timeLabel" text="00:00" />
               </children>
               <HBox.margin>
                  <Insets left="10.0" />
               </HBox.margin>
            </HBox>
            <HBox fx:id="logOutHBox" alignment="CENTER_RIGHT" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Button fx:id="registerNewUserButton" mnemonicParsing="false" text="Register New User">
                     <HBox.margin>
                        <Insets right="5.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="logOutButton" mnemonicParsing="false" text="Log Out">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </HBox>
   </top>	
</BorderPane>
