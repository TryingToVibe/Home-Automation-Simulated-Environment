<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.PasswordField?>

<StackPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="userAuthentication.LoginController">
   <children>
      <VBox fx:id="loginCard" alignment="CENTER" maxWidth="420.0" maxHeight="320.0" prefWidth="380.0" prefHeight="300.0" spacing="12.0">
         <children>
           <Label fx:id="titleLabel" alignment="CENTER" contentDisplay="CENTER" prefHeight="40.0" prefWidth="320.0" text="Smart Home System">
               <VBox.margin>
                  <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
               </VBox.margin>
               <font>
                  <Font name="System Bold Italic" size="16.0" />
               </font>
            </Label>

            <TextField fx:id="usernameField" prefHeight="40.0" prefWidth="215.0" promptText="Enter Username">
    		<!--	<VBox.margin>
        			<Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
   				 </VBox.margin> -->
			</TextField>

           <TextField fx:id="passwordField" prefHeight="40.0" prefWidth="215.0" promptText="Enter Password">
   				<!-- <VBox.margin>
       				 <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
    			 </VBox.margin> -->
			</TextField>

            <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handelLogin" prefHeight="33.0" prefWidth="140.0" text="Login">
              <!-- <VBox.margin>
                  <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
               </padding> -->
            </Button>

            <Button fx:id="registerButton" mnemonicParsing="false" onAction="#handelRegister" prefHeight="33.0" prefWidth="140.0" text="Register">
              <!-- <VBox.margin>
                  <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
               </padding> -->
            </Button>

            <Label fx:id="messageLabel">
              <!-- <VBox.margin>
                  <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
               </padding> -->
            </Label>
         </children>
      </VBox>
   </children>
</StackPane>